// Nirpay — CBDC Backend (PostgreSQL + Prisma)
// Database Schema (DBML) — v1.0
// Last updated: 2026-07-12
// Engine: CBDC Core — Global Ledger, Reconciliation, Cascade Rollback

// ═════════════════════════════════════════════════════════════════════════════
// ENUM REFERENCE
//
// users.role
//   USER | ADMIN | SUPER_ADMIN
//
// users.kyc_status
//   UNVERIFIED | PENDING | APPROVED | REJECTED
//
// global_ledger.tx_type
//   TOPUP | P2P_TRANSFER | WITHDRAW | MERCHANT_PAYMENT | REFUND | MANUAL_MINT | ROLLBACK | ADJUSTMENT | DISPUTE_REFUND
//
// global_ledger.direction
//   SEND | RECEIVE
//
// global_ledger.status
//   SYNCED    → transaksi valid, tercatat di ledger
//   REJECTED  → transaksi ditolak, rollback diperlukan
//   FROZEN    → transaksi dibekukan oleh admin, belum diproses
//
// global_ledger.reject_reason
//   DOUBLE_SPEND | CHAIN_FORK | INSUFFICIENT_BALANCE | HOP_EXCEEDED
//   SIG_INVALID | EXPIRED | CASCADE_PARENT_REJECTED | MANUAL_ADMIN | FORCE_CLOSED
//
// global_ledger.transfer_medium
//   NFC | BLUETOOTH | ONLINE
//
// topup_requests.status
//   PENDING | CONFIRMED | EXPIRED | FAILED
//
// topup_requests.payment_method
//   VIRTUAL_ACCOUNT | QRIS | BANK_TRANSFER
//
// claim_requests.status
//   SUBMITTED | UNDER_REVIEW | RESOLVED | REJECTED
//
// kyc_audit_logs.action
//   SUBMITTED | APPROVED | REJECTED | RETRY_REQUESTED
//
// audit_logs.event_type
//   AUTH_LOGIN | AUTH_LOGOUT | AUTH_REGISTER | AUTH_PASSWORD_CHANGE | AUTH_TOKEN_REFRESH
//   TX_SYNC | TX_TRANSFER | TX_TOPUP | TX_ROLLBACK | TX_REJECT
//   ADMIN_USER_APPROVE | ADMIN_USER_REJECT | ADMIN_MINT | ADMIN_FORCE_ROLLBACK
//   SECURITY_RATE_LIMIT | SECURITY_SUSPICIOUS | SECURITY_API_KEY
// ═════════════════════════════════════════════════════════════════════════════

// ═════════════════════════════════════════════════════════════════════════════
// USERS
// ═════════════════════════════════════════════════════════════════════════════

Table users {
  id                uuid      [pk, default: `gen_random_uuid()`, note: 'Server-side UUID — PRIMARY KEY di server']
  email             text      [not null, unique, note: 'Email unik, case-insensitive']
  username          text      [unique, note: 'Username unik (@prefix disimpan tanpa @)']
  full_name         text      [not null, note: 'Nama sesuai KYC']
  phone_number      text      [unique, null, note: 'Nomor ponsel internasional (+62...)']
  password_hash     text      [not null, note: 'Argon2id hash dari password login']
  pin_hash          text      [not null, note: 'Argon2id hash dari PIN 6 digit transaksi']
  public_key_b64    text      [null, note: 'Ed25519 public key (Base64) — untuk verifikasi sender signature']
  role              text      [not null, default: 'USER', note: 'USER | ADMIN | SUPER_ADMIN']
  is_kyc_done       boolean   [not null, default: false, note: 'Shortcut: true jika kyc_status = APPROVED']
  kyc_status        text      [not null, default: 'UNVERIFIED', note: 'UNVERIFIED | PENDING | APPROVED | REJECTED']
  kyc_face_url      text      [null, note: 'URL foto wajah di object storage']
  kyc_submitted_at  timestamp [null, note: 'Timestamp saat foto KYC disubmit']
  kyc_reviewed_at   timestamp [null, note: 'Timestamp saat KYC di-review admin']
  kyc_reject_reason text      [null, note: 'Alasan ditolak']
  gender            text      [null, note: 'MALE | FEMALE']
  birth_date        date      [null, note: 'YYYY-MM-DD']
  is_active         boolean   [not null, default: true, note: 'false = account suspended/blocked']
  is_locked         boolean   [not null, default: false, note: 'true = akun dikunci karena suspicious activity']
  locked_reason     text      [null, note: 'Alasan akun dikunci']
  failed_login_count integer  [not null, default: 0, note: 'Counter untuk rate limiting login']
  last_login_at     timestamp [null]
  last_login_ip     text      [null]
  created_at        timestamp [not null, default: `now()`]
  updated_at        timestamp [not null, default: `now()`]

  indexes {
    email           [unique, name: 'idx_users_email']
    phone_number    [unique, name: 'idx_users_phone']
    username        [unique, name: 'idx_users_username']
    kyc_status      [name: 'idx_users_kyc']
    is_active       [name: 'idx_users_active']
    created_at      [name: 'idx_users_created']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// WALLET BALANCES
//
// Satu user = satu wallet. Ini adalah GROUND TRUTH saldo di server.
// Client mengirim local_balance_before saat sync — server pakai untuk
// mendeteksi manipulasi saldo.
//
// SERVER BALANCE FORMULA:
//   spendable_cent = amount_cent - reserved_cent
//
//   amount_cent     = saldo aktual (ground truth)
//   reserved_cent   = total tx SEND yang sedang diproses (opsional, server-side)
// ═════════════════════════════════════════════════════════════════════════════

Table wallet_balances {
  id          uuid      [pk, default: `gen_random_uuid()`]
  user_id     uuid      [not null, unique, ref: > users.id, note: 'Satu user satu wallet']
  amount_cent bigint    [not null, default: 0, note: 'Saldo aktual server. Rp 50.000 = 5.000.000']
  reserved_cent bigint  [not null, default: 0, note: 'Saldo terkunci untuk tx pending (opsional server-side)']
  currency    text      [not null, default: 'IDR']
  max_hop     integer   [not null, default: 3, note: 'Batas hop per-user. Bisa diupdate admin.']
  total_minted bigint   [not null, default: 0, note: 'Total CBDC yang pernah dimint ke wallet ini']
  total_sent  bigint    [not null, default: 0, note: 'Total yang pernah dikirim (untuk analytics)']
  total_received bigint [not null, default: 0, note: 'Total yang pernah diterima (untuk analytics)']
  last_tx_at  timestamp [null, note: 'Timestamp transaksi terakhir']
  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  indexes {
    user_id     [unique, name: 'idx_wallet_user']
    amount_cent [name: 'idx_wallet_balance']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// GLOBAL LEDGER
//
// INI TABEL PALING KRITIS DI SELURUH SISTEM.
//
// Semua transaksi CBDC tercatat di sini — baik yang dikirim offline maupun
// online. Server adalah HAKIM FINAL untuk validitas transaksi.
//
// COLUMS KEY:
//   mint_tx_id    → ID token CBDC sejak pertama diterbitkan (KONSTAN)
//   hop_count     → nomor urut hop dalam chain
//   parent_tx_id  → tx sebelumnya (linked list → chain reconstruction)
//
// PROTEKSI:
//   UNIQUE(mint_tx_id, hop_count)  → deteksi chain fork / double-spend
//   index(mint_tx_id)              → rekonstruksi chain cepat
//   index(parent_tx_id)            → cascade rollback cepat
//
// CHAIN OF CUSTODY:
//   Bank menerbitkan TOPUP → mint_tx_id = tx_id TOPUP, hop = 0
//   User A kirim ke B      → mint_tx_id = tx_id TOPUP, hop = 1, parent = TOPUP
//   User B kirim ke C      → mint_tx_id = tx_id TOPUP, hop = 2, parent = hop-1
//   ...dst sampai max_hop
//
// SETELAH REJECT:
//   Semua tx dengan parent_tx_id = tx yang di-reject → CASCADE reject
// ═════════════════════════════════════════════════════════════════════════════

Table global_ledger {
  id                bigserial [pk, note: 'Auto-increment ID']
  tx_id             uuid      [not null, unique, note: 'UUID v4 — ID transaksi. UNIQEUE = anti double-spend']
  mint_tx_id        uuid      [not null, note: 'tx_id TOPUP/mint asal token. KONSTAN sepanjang chain.']
  hop_count         integer   [not null, note: 'Nomor urut hop dalam chain. 0 = TOPUP langsung dari bank']
  parent_tx_id      uuid      [null, note: 'tx_id sebelumnya dalam chain. NULL untuk TOPUP (hop=0)']

  // ── Pihak ──
  sender_id         uuid      [not null, ref: > users.id, note: 'User pengirim']
  receiver_id       uuid      [not null, ref: > users.id, note: 'User penerima']

  // ── Klasifikasi ──
  tx_type           text      [not null, note: 'TOPUP | P2P_TRANSFER | WITHDRAW | MERCHANT_PAYMENT | REFUND | MANUAL_MINT | ROLLBACK | ADJUSTMENT | DISPUTE_REFUND']
  direction         text      [not null, note: 'SEND | RECEIVE (satu baris per sisi)']
  transfer_medium   text      [not null, note: 'NFC | BLUETOOTH | ONLINE']

  // ── Nominal ──
  amount_cent       bigint    [not null, note: 'Nominal dalam cents (Rp 1 = 100)']
  fee_cent          bigint    [not null, default: 0]
  currency          text      [not null, default: 'IDR']

  // ── Signature ──
  bank_signature_b64   text   [null, note: 'Ed25519 signature Bank atas payload (untuk TOPUP)']
  sender_signature_b64 text   [null, note: 'Ed25519 signature pengirim (untuk P2P)']

  // ── Expiry ──
  expires_at        timestamp [not null, note: 'timestamp + 72 jam. Tolak RECEIVE jika expired']

  // ── Status ──
  status            text      [not null, default: 'SYNCED', note: 'SYNCED | REJECTED | FROZEN']
  reject_reason     text      [null, note: 'DOUBLE_SPEND | CHAIN_FORK | INSUFFICIENT_BALANCE | HOP_EXCEEDED | SIG_INVALID | EXPIRED | CASCADE_PARENT_REJECTED | MANUAL_ADMIN | FORCE_CLOSED']

  // ── Balance Snapshot ──
  sender_balance_before   bigint [null, note: 'Snapshot saldo sender SEBELUM tx. Server pakai untuk validasi']
  receiver_balance_before bigint [null, note: 'Snapshot saldo receiver SEBELUM tx']
  sender_balance_after    bigint [null, note: 'Saldo sender SETELAH tx diproses']
  receiver_balance_after  bigint [null, note: 'Saldo receiver SETELAH tx diproses']

  // ── Audit ──
  raw_payload_b64   text      [null, note: 'Raw payload dari client (NFC/BT). Server verifikasi ulang dari sini']
  note              text      [null, note: 'Catatan transaksi']
  processed_at      timestamp [not null, default: `now()`, note: 'Server timestamp saat tx diproses']
  created_at        timestamp [not null, default: `now()`]

  indexes {
    tx_id                       [unique, name: 'idx_ledger_tx_id']
    (mint_tx_id, hop_count)     [unique, name: 'idx_ledger_chain_fork', note: 'ANTI FORK: satu mint_tx_id hanya boleh punya satu tx per hop']
    mint_tx_id                  [name: 'idx_ledger_mint', note: 'Rekonstruksi chain cepat']
    parent_tx_id                [name: 'idx_ledger_parent', note: 'Cascade traversal']
    sender_id                   [name: 'idx_ledger_sender']
    receiver_id                 [name: 'idx_ledger_receiver']
    status                      [name: 'idx_ledger_status']
    (sender_id, status)         [name: 'idx_ledger_sender_status']
    (receiver_id, status)       [name: 'idx_ledger_receiver_status']
    created_at                  [name: 'idx_ledger_created']
    tx_type                     [name: 'idx_ledger_type']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// DEVICE SESSIONS
//
// JWT session management. Satu device = satu session active.
// ═════════════════════════════════════════════════════════════════════════════

Table device_sessions {
  id            uuid      [pk, default: `gen_random_uuid()`]
  user_id       uuid      [not null, ref: > users.id]
  device_id     text      [null, note: 'Device fingerprint / FCM token']
  device_name   text      [null, note: 'Nama device untuk display: "Samsung Galaxy S24"']
  ip_address    text      [null, note: 'IP address terakhir']
  auth_token    text      [not null, note: 'JWT access token (hashed untuk penyimpanan)']
  refresh_token text      [null, note: 'JWT refresh token (hashed)']
  is_revoked    boolean   [not null, default: false, note: 'true = session sudah logout']
  expires_at    timestamp [not null, note: 'Access token expiry']
  last_active_at timestamp [null, note: 'Terakhir kali request dengan token ini']
  created_at    timestamp [not null, default: `now()`]

  indexes {
    (user_id, is_revoked)   [name: 'idx_session_user']
    auth_token              [unique, name: 'idx_session_token']
    expires_at              [name: 'idx_session_expiry']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// OTP VERIFICATIONS
// ═════════════════════════════════════════════════════════════════════════════

Table otp_verifications {
  id            uuid      [pk, default: `gen_random_uuid()`]
  email         text      [not null, note: 'Email tujuan OTP']
  otp_hash      text      [not null, note: 'Hash dari 6-digit OTP']
  channel       text      [not null, note: 'EMAIL | SMS']
  purpose       text      [not null, note: 'REGISTER | LOGIN | FORGOT_PASSWORD | VERIFY_PHONE']
  attempt_count integer   [not null, default: 0, note: 'Percobaan verifikasi OTP']
  max_attempts  integer   [not null, default: 5]
  is_used       boolean   [not null, default: false]
  expires_at    timestamp [not null, note: 'OTP expiry (5 menit)']
  created_at    timestamp [not null, default: `now()`]

  indexes {
    (email, purpose, is_used) [name: 'idx_otp_lookup']
    expires_at                [name: 'idx_otp_expiry']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// PASSWORD RESETS
// ═════════════════════════════════════════════════════════════════════════════

Table password_resets {
  id         uuid      [pk, default: `gen_random_uuid()`]
  user_id    uuid      [not null, ref: > users.id]
  token_hash text      [not null, note: 'SHA-256 hash dari reset token']
  is_used    boolean   [not null, default: false]
  expires_at timestamp [not null, note: 'Reset link expiry (1 jam)']
  created_at timestamp [not null, default: `now()`]

  indexes {
    token_hash  [unique, name: 'idx_reset_token']
    user_id     [name: 'idx_reset_user']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// TOPUP REQUESTS
// ═════════════════════════════════════════════════════════════════════════════

Table topup_requests {
  id             uuid      [pk, default: `gen_random_uuid()`]
  user_id        uuid      [not null, ref: > users.id]
  mint_tx_id     uuid      [null, note: 'tx_id yang dihasilkan saat mint berhasil (isi setelah confirmed)']
  amount_cent    bigint    [not null]
  currency       text      [not null, default: 'IDR']
  payment_method text      [not null, note: 'VIRTUAL_ACCOUNT | QRIS | BANK_TRANSFER']
  va_number      text      [null, note: 'Nomor Virtual Account (generated)']
  bank_code      text      [null, note: 'Kode bank tujuan']
  status         text      [not null, default: 'PENDING', note: 'PENDING | CONFIRMED | EXPIRED | FAILED']
  server_ref     text      [null, note: 'Referensi dari payment gateway']
  pg_reference   text      [null, note: 'Payment gateway reference ID']
  expired_at     timestamp [null, note: 'Batas waktu pembayaran (24 jam)']
  confirmed_at   timestamp [null, note: 'Timestamp pembayaran dikonfirmasi']
  created_at     timestamp [not null, default: `now()`]
  updated_at     timestamp [not null, default: `now()`]

  indexes {
    (user_id, status)  [name: 'idx_topup_user_status']
    va_number          [name: 'idx_topup_va']
    status             [name: 'idx_topup_status']
    expired_at         [name: 'idx_topup_expiry']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// CLAIM REQUESTS
// ═════════════════════════════════════════════════════════════════════════════

Table claim_requests {
  id              uuid      [pk, default: `gen_random_uuid()`]
  user_id         uuid      [not null, ref: > users.id]
  tx_id           uuid      [not null, ref: > global_ledger.tx_id, note: 'Transaksi yang diklaim']
  reason          text      [not null, note: 'Alasan klaim dari user']
  evidence_urls   text[]    [null, note: 'Array URL bukti (screenshot, foto)']
  status          text      [not null, default: 'SUBMITTED', note: 'SUBMITTED | UNDER_REVIEW | RESOLVED | REJECTED']
  admin_id        uuid      [null, ref: > users.id, note: 'Admin yang menangani']
  resolution      text      [null, note: 'Hasil keputusan admin']
  refund_amount_cent bigint [null, note: 'Jumlah yang dikembalikan jika RESOLVED']
  submitted_at    timestamp [not null, default: `now()`]
  reviewed_at     timestamp [null]
  resolved_at     timestamp [null]
  created_at      timestamp [not null, default: `now()`]
  updated_at      timestamp [not null, default: `now()`]

  indexes {
    (user_id, status)  [name: 'idx_claim_user_status']
    tx_id              [name: 'idx_claim_tx']
    status             [name: 'idx_claim_status']
    admin_id           [name: 'idx_claim_admin']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// ANOMALY REPORTS
//
// Anomaly logs dari client yang dikirim saat sync.
// Server pakai untuk: fraud detection pipeline, flagging akun, analisis pola.
// ═════════════════════════════════════════════════════════════════════════════

Table anomaly_logs {
  id              uuid      [pk, default: `gen_random_uuid()`]
  user_id         uuid      [not null, ref: > users.id]
  tx_id           uuid      [null, ref: > global_ledger.tx_id, note: 'Ter关联 tx. NULL jika anomali sebelum tx']
  anomaly_type    text      [not null, note: 'DOUBLE_SPEND_ATTEMPT | INSUFFICIENT_BALANCE | HOP_EXCEEDED | EXPIRED_TX | SIG_INVALID | REPLAY_ATTEMPT | TAMPERED_PAYLOAD | HOP_MISMATCH | CHAIN_FORK | RECEIVED_FRAUDULENT_TX | CASCADE_REJECTED']
  severity        text      [not null, default: 'MEDIUM', note: 'LOW | MEDIUM | HIGH | CRITICAL']
  detected_at     timestamp [not null, note: 'Client timestamp saat anomali terdeteksi']
  server_received_at timestamp [not null, default: `now()`]
  detail          jsonb     [null, note: 'JSON konteks: { attempted_amount, spendable, claimed_hop, chain_hop, mint_tx_id, ... }']
  raw_payload_b64 text      [null, note: 'Raw payload pemicu anomali (forensik)']
  is_reviewed     boolean   [not null, default: false]
  reviewed_by     uuid      [null, ref: > users.id]
  reviewed_at     timestamp [null]
  action_taken    text      [null, note: 'Tindakan yang diambil: FLAGGED | WARNED | BLOCKED | NO_ACTION']
  created_at      timestamp [not null, default: `now()`]

  indexes {
    user_id                     [name: 'idx_anomaly_user']
    anomaly_type                [name: 'idx_anomaly_type']
    severity                    [name: 'idx_anomaly_severity']
    (user_id, anomaly_type)     [name: 'idx_anomaly_user_type']
    detected_at                 [name: 'idx_anomaly_time']
    is_reviewed                 [name: 'idx_anomaly_unreviewed']
    tx_id                       [name: 'idx_anomaly_tx']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// KYC AUDIT LOGS
//
// Audit trail untuk semua perubahan status KYC.
// ═════════════════════════════════════════════════════════════════════════════

Table kyc_audit_logs {
  id          uuid      [pk, default: `gen_random_uuid()`]
  user_id     uuid      [not null, ref: > users.id]
  action      text      [not null, note: 'SUBMITTED | APPROVED | RETRY_REQUESTED | REJECTED']
  admin_id    uuid      [null, ref: > users.id, note: 'Admin yang melakukan aksi']
  old_status  text      [null, note: 'Status KYC sebelum aksi']
  new_status  text      [not null, note: 'Status KYC setelah aksi']
  reason      text      [null, note: 'Alasan (untuk REJECTED)']
  face_url    text      [null, note: 'URL foto wajah yang diupload']
  created_at  timestamp [not null, default: `now()`]

  indexes {
    user_id     [name: 'idx_kyc_audit_user']
    action      [name: 'idx_kyc_audit_action']
    created_at  [name: 'idx_kyc_audit_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// AUDIT LOGS
//
// Global audit trail untuk semua operasi penting.
// APPEND-ONLY — tidak boleh dihapus atau diubah.
// ═════════════════════════════════════════════════════════════════════════════

Table audit_logs {
  id           uuid      [pk, default: `gen_random_uuid()`]
  actor_id     uuid      [null, ref: > users.id, note: 'User/admin yang melakukan aksi. NULL untuk system']
  actor_role   text      [null, note: 'USER | ADMIN | SUPER_ADMIN | SYSTEM']
  event_type   text      [not null, note: 'AUTH_LOGIN | AUTH_LOGOUT | ... (lihat enum reference)']
  resource_type text     [null, note: 'USER | WALLET | LEDGER | CLAIM | TOPUP']
  resource_id  text      [null, note: 'ID dari resource yang terpengaruh']
  ip_address   text      [null]
  user_agent   text      [null]
  detail       jsonb     [null, note: 'JSON detail: { old_value, new_value, ... }']
  created_at   timestamp [not null, default: `now()`]

  indexes {
    actor_id          [name: 'idx_audit_actor']
    event_type        [name: 'idx_audit_event']
    resource_type     [name: 'idx_audit_resource']
    (resource_type, resource_id) [name: 'idx_audit_resource_id']
    created_at        [name: 'idx_audit_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// SYSTEM CONFIG
//
// Konfigurasi global sistem. Bisa diubah oleh SUPER_ADMIN via dashboard.
// ═════════════════════════════════════════════════════════════════════════════

Table system_config {
  id          uuid      [pk, default: `gen_random_uuid()`]
  key         text      [not null, unique, note: 'Nama konfigurasi: max_hop, default_fee, etc.']
  value       text      [not null, note: 'Nilai (stored sebagai string, di-parse per type)']
  value_type  text      [not null, note: 'STRING | INTEGER | BOOLEAN | JSON']
  description text      [null, note: 'Deskripsi untuk admin']
  updated_by  uuid      [null, ref: > users.id]
  updated_at  timestamp [not null, default: `now()`]
  created_at  timestamp [not null, default: `now()`]

  indexes {
    key [unique, name: 'idx_config_key']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// WEBHOOK LOGS
//
// Log semua webhook yang diterima dari payment gateway / bank eksternal.
// Untuk debugging dan idempotency check.
// ═════════════════════════════════════════════════════════════════════════════

Table webhook_logs {
  id             uuid      [pk, default: `gen_random_uuid()`]
  source         text      [not null, note: 'PAYMENT_GATEWAY | BANK | MOCK_BANK']
  event_type     text      [not null, note: 'payment.confirmed | payment.failed | ...']
  reference_id   text      [null, note: 'ID referensi dari payload']
  payload        jsonb     [not null, note: 'Full webhook payload']
  signature_valid boolean [not null, note: 'Apakah signature terverifikasi']
  is_processed   boolean   [not null, default: false]
  processed_at   timestamp [null]
  error_message  text      [null]
  created_at     timestamp [not null, default: `now()`]

  indexes {
    source               [name: 'idx_webhook_source']
    (source, reference_id) [name: 'idx_webhook_idempotent', note: 'Cek idempotency']
    is_processed         [name: 'idx_webhook_pending']
    created_at           [name: 'idx_webhook_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// RATE LIMIT TRACKING
//
// Rate limiting state (bisa juga pakai Redis, tapi ini sebagai fallback).
// ═════════════════════════════════════════════════════════════════════════════

Table rate_limits {
  id          uuid      [pk, default: `gen_random_uuid()`]
  identifier  text      [not null, note: 'email / IP / user_id']
  action      text      [not null, note: 'LOGIN | SEND_OTP | SYNC | TRANSFER']
  count       integer   [not null, default: 1]
  window_start timestamp [not null, default: `now()`]
  expires_at  timestamp [not null]

  indexes {
    (identifier, action, window_start) [unique, name: 'idx_ratelimit_key']
    expires_at                         [name: 'idx_ratelimit_expiry']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// FROZEN TRANSACTIONS
//
// Transaksi yang dibekukan oleh admin. Bisa HOLD (sementara) atau FORCE_REJECT.
// Transaksi yang di-freeze tidak akan diproses saat sync client.
// ═════════════════════════════════════════════════════════════════════════════

Table frozen_transactions {
  id            uuid      [pk, default: `gen_random_uuid()`]
  tx_id         uuid      [not null, unique, ref: > global_ledger.tx_id, note: 'Transaksi yang dibekukan']
  frozen_by     uuid      [not null, ref: > users.id, note: 'Admin yang membekukan']
  freeze_type   text      [not null, note: 'HOLD | FORCE_REJECT']
  reason        text      [not null, note: 'Alasan pembekuan']
  notes         text      [null, note: 'Catatan internal admin']
  status        text      [not null, default: 'FROZEN', note: 'FROZEN | UNFROZEN | FORCE_REJECTED']
  unfrozen_by   uuid      [null, ref: > users.id, note: 'Admin yang unfreeze (jika HOLD)']
  unfrozen_at   timestamp [null]
  unfreeze_reason text    [null, note: 'Alasan unfreeze']
  created_at    timestamp [not null, default: `now()`]

  indexes {
    tx_id           [unique, name: 'idx_frozen_tx']
    status          [name: 'idx_frozen_status']
    frozen_by       [name: 'idx_frozen_by']
    created_at      [name: 'idx_frozen_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// FROZEN ACCOUNTS
//
// User yang akunnya dibekukan oleh admin. Tidak bisa kirim/terima/sync.
// ═════════════════════════════════════════════════════════════════════════════

Table frozen_accounts {
  id            uuid      [pk, default: `gen_random_uuid()`]
  user_id       uuid      [not null, ref: > users.id, note: 'User yang akunnya dibekukan']
  frozen_by     uuid      [not null, ref: > users.id, note: 'Admin yang membekukan']
  reason        text      [not null, note: 'Alasan pembekuan akun']
  status        text      [not null, default: 'FROZEN', note: 'FROZEN | UNFROZEN']
  unfrozen_by   uuid      [null, ref: > users.id]
  unfrozen_at   timestamp [null]
  unfreeze_reason text    [null]
  created_at    timestamp [not null, default: `now()`]

  indexes {
    user_id     [unique, name: 'idx_frozen_account_user']
    status      [name: 'idx_frozen_account_status']
    created_at  [name: 'idx_frozen_account_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// BALANCE ADJUSTMENTS
//
// Record semua perubahan saldo yang dilakukan admin (CREDIT/DEBIT).
// Setiap adjustment tercatat di sini dan bisa didispute oleh user.
// ═════════════════════════════════════════════════════════════════════════════

Table balance_adjustments {
  id                uuid      [pk, default: `gen_random_uuid()`]
  user_id           uuid      [not null, ref: > users.id, note: 'User yang saldonya diubah']
  admin_id          uuid      [not null, ref: > users.id, note: 'Admin yang melakukan adjustment']
  adjustment_type   text      [not null, note: 'CREDIT | DEBIT']
  amount_cent       bigint    [not null, note: 'Nominal adjustment (selalu positif)']
  reason            text      [not null, note: 'Alasan adjustment']
  reference_tx_id   uuid      [null, ref: > global_ledger.tx_id, note: 'TX terkait (opsional)']
  admin_notes       text      [null, note: 'Catatan internal admin']
  balance_before    bigint    [not null, note: 'Saldo SEBELUM adjustment']
  balance_after     bigint    [not null, note: 'Saldo SETELAH adjustment']
  status            text      [not null, default: 'COMPLETED', note: 'COMPLETED | REVERSED']
  reversed_by       uuid      [null, ref: > users.id, note: 'Admin yang membatalkan adjustment']
  reversed_at       timestamp [null]
  reverse_reason    text      [null]
  created_at        timestamp [not null, default: `now()`]

  indexes {
    user_id                     [name: 'idx_adj_user']
    admin_id                    [name: 'idx_adj_admin']
    adjustment_type             [name: 'idx_adj_type']
    (user_id, created_at)       [name: 'idx_adj_user_time']
    reference_tx_id             [name: 'idx_adj_tx']
    created_at                  [name: 'idx_adj_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// DISPUTES
//
// Client membanding keputusan admin (freeze, balance adjust, claim reject).
// User memberikan bukti, admin review dan putuskan.
// ═════════════════════════════════════════════════════════════════════════════

Table disputes {
  id              uuid      [pk, default: `gen_random_uuid()`]
  user_id         uuid      [not null, ref: > users.id, note: 'User yang mengajukan banding']
  dispute_type    text      [not null, note: 'TRANSACTION_FROZEN | BALANCE_ADJUSTMENT | CLAIM_REJECTED | ACCOUNT_FROZEN | OTHER']
  reference_id    uuid      [not null, note: 'ID dari objek yang didispute (tx_id, adjustment_id, claim_id)']
  reference_type  text      [not null, note: 'TRANSACTION | BALANCE_ADJUSTMENT | CLAIM | ACCOUNT']
  title           text      [not null, note: 'Judul singkat dispute']
  description     text      [not null, note: 'Penjelasan detail dari user']
  evidence_urls   text[]    [null, note: 'Array URL bukti (screenshot, dokumen, dll)']
  status          text      [not null, default: 'SUBMITTED', note: 'SUBMITTED | UNDER_REVIEW | ACCEPTED | PARTIAL_ACCEPTED | REJECTED']
  admin_id        uuid      [null, ref: > users.id, note: 'Admin yang review']
  decision        text      [null, note: 'ACCEPT | PARTIAL_ACCEPT | REJECTED']
  resolution      text      [null, note: 'Penjelasan keputusan admin']
  refund_amount_cent bigint [null, note: 'Jumlah yang dikembalikan jika ACCEPT']
  original_action_amount bigint [null, note: 'Jumlah asli dari aksi admin yang didispute']
  submitted_at    timestamp [not null, default: `now()`]
  reviewed_at     timestamp [null]
  resolved_at     timestamp [null]
  created_at      timestamp [not null, default: `now()`]
  updated_at      timestamp [not null, default: `now()`]

  indexes {
    user_id                     [name: 'idx_dispute_user']
    dispute_type                [name: 'idx_dispute_type']
    (reference_type, reference_id) [name: 'idx_dispute_reference']
    status                      [name: 'idx_dispute_status']
    admin_id                    [name: 'idx_dispute_admin']
    submitted_at                [name: 'idx_dispute_submitted']
    created_at                  [name: 'idx_dispute_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// ADMIN ACTIONS
//
// Audit trail untuk SEMUA tindakan admin. APPEND-ONLY.
// Setiap freeze, unfreeze, adjust balance, review dispute, dll tercatat di sini.
// ═════════════════════════════════════════════════════════════════════════════

Table admin_actions {
  id              uuid      [pk, default: `gen_random_uuid()`]
  admin_id        uuid      [not null, ref: > users.id, note: 'Admin yang melakukan aksi']
  action_type     text      [not null, note: 'FREEZE_TX | UNFREEZE_TX | FORCE_CLOSE_CHAIN | FREEZE_ACCOUNT | UNFREEZE_ACCOUNT | ADJUST_BALANCE | MINT_CBDC | FORCE_ROLLBACK | APPROVE_KYC | REJECT_KYC | REVIEW_DISPUTE']
  target_type     text      [not null, note: 'TRANSACTION | ACCOUNT | BALANCE | KYC | DISPUTE | CBDC']
  target_id       uuid      [not null, note: 'ID dari objek yang dikenai aksi']
  target_user_id  uuid      [null, ref: > users.id, note: 'User terpengaruh (opsional)']
  reason          text      [not null, note: 'Alasan aksi']
  detail          jsonb     [null, note: 'JSON detail: { old_value, new_value, amount_cent, ... }']
  ip_address      text      [null]
  created_at      timestamp [not null, default: `now()`]

  indexes {
    admin_id                    [name: 'idx_admin_action_admin']
    action_type                 [name: 'idx_admin_action_type']
    (target_type, target_id)    [name: 'idx_admin_action_target']
    target_user_id              [name: 'idx_admin_action_user']
    created_at                  [name: 'idx_admin_action_time']
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// RELATIONSHIPS SUMMARY
// ═════════════════════════════════════════════════════════════════════════════

// users ─1:1─ wallet_balances
//   │
//   1:N── global_ledger (as sender_id)
//   1:N── global_ledger (as receiver_id)
//   │
//   1:N── device_sessions
//   1:N── otp_verifications (via email)
//   1:N── password_resets
//   1:N── topup_requests
//   1:N── claim_requests
//   1:N── anomaly_logs
//   1:N── kyc_audit_logs
//   1:N── audit_logs (as actor_id)
//   1:N── frozen_transactions (as frozen_by)
//   1:N── frozen_accounts (as frozen_by)
//   1:N── balance_adjustments (as admin_id)
//   1:N── disputes (as user_id)
//   1:N── admin_actions (as admin_id)
//   1:N── webhook_logs (indirect)
//
// global_ledger:
//   self-referencing: parent_tx_id → tx_id (chain traversal)
//   mint_tx_id: grouping token asal
//
// frozen_transactions ──► global_ledger (via tx_id)
// balance_adjustments ──► global_ledger (via reference_tx_id, nullable)
// disputes ──► global_ledger (via reference_id, nullable)
// admin_actions ──► users (via target_user_id, nullable)
