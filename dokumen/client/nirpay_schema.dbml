// Nirpay — Offline + Online CBDC Client
// Database Schema (DBML) — v4 FINAL
// Last updated: 2026-07-12
// Proteksi: double-spend, hop manipulation, cascade rollback, chain fork, replay

// ═════════════════════════════════════════════════════════════════════════════
// ENUM REFERENCE
// (SQLite tidak support native ENUM — gunakan TEXT + CHECK di app layer)
//
// users.kyc_status
//   UNVERIFIED | PENDING | APPROVED | REJECTED
//
// transactions.direction
//   SEND | RECEIVE
//
// transactions.tx_type
//   P2P_TRANSFER | TOPUP | WITHDRAW | MERCHANT_PAYMENT | REFUND
//
// transactions.transfer_medium
//   NFC | BLUETOOTH | ONLINE
//
// transactions.sync_status
//   PENDING   → baru dibuat di device, belum dikirim ke server
//   SYNCED    → server konfirmasi valid
//   REJECTED  → server tolak, rollback diperlukan
//   N/A       → hanya untuk ONLINE tx (langsung kirim ke server, tidak antri)
//
// transactions.verify_status  (hasil verifikasi LOKAL di device penerima)
//   UNVERIFIED         → belum dicek
//   SIG_OK             → semua signature valid
//   SIG_FAIL           → signature bank/sender tidak valid
//   EXPIRED            → expires_at sudah lewat
//   HOP_EXCEEDED       → hop_count >= max_hop saat diterima
//   HOP_MISMATCH       → chain_hop_count ≠ hop_count (diklaim vs dihitung)
//   BALANCE_FAIL       → saldo tidak cukup saat SEND
//   CHAIN_FORK_DETECTED→ mint_tx_id + hop_count sudah ada di DB (replay/fork)
//
// anomaly_logs.anomaly_type
//   DOUBLE_SPEND_ATTEMPT    → coba kirim tx_id yang sudah ada
//   INSUFFICIENT_BALANCE    → coba kirim melebihi spendable
//   HOP_EXCEEDED            → coba kirim/terima saat hop >= max
//   EXPIRED_TX              → terima token yang sudah lewat expires_at
//   SIG_INVALID             → signature tidak valid
//   REPLAY_ATTEMPT          → tx_id atau (mint_tx_id+hop) sudah ada di DB
//   TAMPERED_PAYLOAD        → raw_payload tidak cocok dengan field yang di-parse
//   HOP_MISMATCH            → chain_hop_count ≠ hop_count yang diklaim
//   CHAIN_FORK              → dua tx dengan mint_tx_id+hop sama terdeteksi
//   RECEIVED_FRAUDULENT_TX  → server bilang tx yang diterima ternyata fraud
//   CASCADE_REJECTED        → tx di-reject karena parent_tx_id-nya di-reject
//
// rollback_queue.rollback_type
//   RELEASE_RESERVE         → lepas reserved_cent (pengirim, tx REJECTED)
//   DEDUCT_RECEIVED         → kurangi amount_cent (penerima, tx REJECTED)
//   CASCADE_DEDUCT          → kurangi amount_cent karena parent REJECTED
//   SERVER_CORRECTION       → koreksi paksa ke server_confirmed_balance
// ═════════════════════════════════════════════════════════════════════════════

Table users {
  id                integer [pk, increment, note: 'ID lokal']
  server_id         text    [unique, null, note: 'UUID dari server Bank']
  email             text    [not null, unique]
  username          text    [unique]
  full_name         text    [not null, note: 'Nama sesuai KYC']
  phone_number      text    [null]
  password_hash     text    [not null, note: 'Argon2/Bcrypt hash dari password login — BEDA dengan pin_hash']
  pin_hash          text    [not null, note: 'Argon2 hash dari PIN 6 digit untuk konfirmasi transaksi']
  public_key_b64    text    [null, note: 'Ed25519 public key (Base64)']
  is_kyc_done       boolean [default: false, note: 'Shortcut: true jika kyc_status = APPROVED']
  kyc_status        text    [default: 'UNVERIFIED', note: 'UNVERIFIED | PENDING | APPROVED | REJECTED']
  kyc_face_url      text    [null, note: 'URL foto wajah di server setelah upload KYC step 4']
  kyc_submitted_at  integer [null, note: 'Unix timestamp saat foto KYC disubmit']
  kyc_reject_reason text    [null, note: 'Alasan ditolak jika kyc_status = REJECTED']
  gender            text    [null, note: 'MALE | FEMALE']
  birth_date        text    [null, note: 'ISO 8601']
  created_at        integer [not null]
  updated_at        integer [not null]
}

// ─────────────────────────────────────────────────────────────────────────────
// wallet_balances — v4
//
// FORMULA SALDO:
//   spendable_cent  = amount_cent - reserved_cent   ← yang boleh dipakai
//   amount_cent     = saldo dikonfirmasi server      ← ground truth terakhir
//   reserved_cent   = total nominal tx PENDING SEND  ← uang "on hold"
//
// ALUR SEND OFFLINE (harus satu SQLite transaction atomik):
//   Pra-kondisi  : hop_count < max_hop
//                  spendable_cent >= amount_kirim
//   1. reserved_cent    += amount_kirim
//   2. hop_count        += 1
//   3. INSERT transactions (sync_status='PENDING', direction='SEND')
//   → COMMIT — jika gagal: ROLLBACK semua
//
// ALUR RECEIVE OFFLINE (harus satu SQLite transaction atomik):
//   Pra-kondisi  : verify_status == 'SIG_OK'
//                  hop_count payload < max_hop
//                  (mint_tx_id, hop_count) belum ada di DB
//                  tx_id belum ada di DB
//   1. amount_cent          += amount_diterima
//   2. pending_receive_hop   = MAX(pending_receive_hop, payload.hop_count)
//   3. INSERT transactions (sync_status='PENDING', direction='RECEIVE')
//   → COMMIT
//
// SETELAH SYNC SYNCED (SEND):
//   amount_cent             = server_balance_after  (pakai nilai dari server)
//   reserved_cent           -= amount_tx
//   server_confirmed_balance = server_balance_after
//   hop_count               = 0                     (reset setelah sync)
//
// SETELAH SYNC REJECTED (SEND):
//   reserved_cent           -= amount_tx            (lepas lock saja)
//   amount_cent tidak berubah
//
// SETELAH SYNC REJECTED (RECEIVE) — ROLLBACK:
//   amount_cent             -= amount_tx            (tarik balik)
//   amount_cent             = server_confirmed_balance (koreksi ke server)
//   pending_receive_hop dihitung ulang dari tx RECEIVE yang masih PENDING
// ─────────────────────────────────────────────────────────────────────────────

Table wallet_balances {
  id                       integer [pk, increment]
  user_id                  integer [not null, unique, ref: - users.id]
  amount_cent              integer [not null, default: 0,
                                     note: 'Saldo total dikonfirmasi server. Ground truth lokal. Rp 50.000 = 5.000.000']
  reserved_cent            integer [not null, default: 0,
                                     note: 'Total nominal tx SEND yang masih PENDING. Harus <= amount_cent. spendable = amount_cent - reserved_cent']
  currency                 text    [not null, default: 'IDR']
  hop_count                integer [not null, default: 0,
                                     note: 'Hop kumulatif sebagai PENGIRIM sejak sync terakhir. Diblokir kirim jika >= max_hop. Reset ke 0 setelah sync berhasil']
  max_hop                  integer [not null, default: 3,
                                     note: 'Batas hop sebelum wajib sync. Dikirim server saat sync — server bisa update nilai ini per-user']
  pending_receive_hop      integer [not null, default: 0,
                                     note: 'Hop tertinggi dari semua RECEIVE yang masih PENDING. UI pakai ini untuk risk warning: >=2 tampilkan peringatan, ==max_hop tampilkan urgensi sync']
  last_synced_at           integer [null, note: 'Unix timestamp sync terakhir berhasil']
  server_confirmed_balance integer [null,
                                     note: 'Saldo resmi dari server response sync terakhir. Baseline reconciliation — jika amount_cent menyimpang dari ini tanpa penjelasan tx, flag sebagai manipulasi']
  updated_at               integer [not null]
}

// ─────────────────────────────────────────────────────────────────────────────
// transactions — v4 HARDENED
//
// TABEL INDUK semua transaksi (NFC, BLUETOOTH, ONLINE).
// Setiap baris = satu sisi transaksi dari sudut pandang user ini.
// Transaksi yang sama menghasilkan dua baris di dua device berbeda:
//   Device A (SEND): tx_id='AAA', direction='SEND'
//   Device B (RECEIVE): tx_id='AAA', direction='RECEIVE'
//
// CHAIN OF CUSTODY (untuk offline):
//   mint_tx_id   → ID konstan sejak Bank menerbitkan token (tidak berubah)
//   parent_tx_id → tx sebelumnya dalam chain (linked list)
//   hop_count    → nomor urut hop yang DIKLAIM pengirim
//   chain_hop_count → nomor urut hop yang DIHITUNG penerima dari chain lokal
//
// PROTEKSI BERLAPIS:
//   L1 (device pengirim) : hop_count >= max_hop → BLOKIR sebelum NFC
//   L2 (device penerima) : verify 4 kondisi sebelum tambah saldo
//   L3 (device penerima) : chain_hop_count vs hop_count → deteksi manipulasi
//   L4 (server sync)     : rekonstruksi chain, deteksi fork, cascade rollback
// ─────────────────────────────────────────────────────────────────────────────

Table transactions {
  id                    integer [pk, increment]
  tx_id                 text    [not null, unique,
                                  note: 'UUID v4 — UNIQUE di DB lokal = lapis pertama anti double-spend & replay']
  user_id               integer [not null, ref: > users.id]

  // ── Klasifikasi ──
  direction             text    [not null, note: 'SEND | RECEIVE']
  tx_type               text    [not null, default: 'P2P_TRANSFER',
                                  note: 'P2P_TRANSFER | TOPUP | WITHDRAW | MERCHANT_PAYMENT | REFUND']
  transfer_medium       text    [not null, default: 'NFC',
                                  note: 'NFC | BLUETOOTH | ONLINE']

  // ── Pihak lawan ──
  counterparty_wallet   text    [not null, note: 'Wallet ID lawan transaksi']
  counterparty_name     text    [null, note: 'Nama tampilan (dari cache/server)']

  // ── Nominal ──
  amount_cent           integer [not null]
  fee_cent              integer [not null, default: 0]
  currency              text    [not null, default: 'IDR']

  // ── Chain of Custody — eksklusif OFFLINE (NULL jika ONLINE) ──
  hop_count             integer [null,
                                  note: 'Nomor hop yang DIKLAIM pengirim. Dicek penerima: harus < max_hop. Dicek server: harus == panjang chain dari mint_tx_id']
  chain_hop_count       integer [null,
                                  note: 'Nomor hop yang DIHITUNG LOKAL oleh penerima dengan menelusuri parent_tx_id di DB. Jika chain_hop_count != hop_count → HOP_MISMATCH → catat anomaly_logs, terima tapi flag untuk server']
  mint_tx_id            text    [null,
                                  note: 'tx_id TOPUP/mint asal token ini. KONSTAN sepanjang seluruh chain. Server query: SELECT * WHERE mint_tx_id=X → semua hop token ini → deteksi fork jika ada dua tx dengan hop_count sama']
  parent_tx_id          text    [null,
                                  note: 'tx_id transaksi sebelumnya dalam chain (RECEIVE yang jadi sumber saldo tx SEND ini, atau tx SEND sebelumnya dari pengirim). Dua fungsi: (1) rekonstruksi chain untuk verifikasi hop, (2) cascade rollback jika parent REJECTED']
  bank_signature_b64    text    [null, note: 'Ed25519 signature Bank Sentral atas seluruh payload (Base64)']
  sender_signature_b64  text    [null, note: 'Ed25519 signature Pengirim (Base64)']
  sender_public_key_b64 text    [null, note: 'Ed25519 public key Pengirim (Base64) — untuk verifikasi sender_signature']
  expires_at            integer [null, note: 'timestamp + 72 jam. Tolak RECEIVE jika now() > expires_at']

  // ── Verifikasi & Audit ──
  verify_status         text    [not null, default: 'UNVERIFIED',
                                  note: 'UNVERIFIED | SIG_OK | SIG_FAIL | EXPIRED | HOP_EXCEEDED | HOP_MISMATCH | BALANCE_FAIL | CHAIN_FORK_DETECTED']
  raw_payload_b64       text    [null,
                                  note: 'Raw bytes payload NFC/BT persis seperti diterima (Base64). Server verifikasi ulang signature dari ini saat sync. Juga dipakai deteksi TAMPERED_PAYLOAD: hash(raw_payload) harus cocok dengan field-field yang di-parse']
  local_balance_before  integer [null,
                                  note: 'Snapshot amount_cent SEBELUM tx ini dieksekusi. Server pakai untuk cascade rollback: apakah user punya saldo cukup jika parent_tx_id-nya di-reject?']

  // ── Status Sync ──
  timestamp             integer [not null, note: 'Unix timestamp saat tx dibuat di device']
  sync_status           text    [not null, default: 'PENDING',
                                  note: 'PENDING | SYNCED | REJECTED | N/A']
  server_balance_after  integer [null,
                                  note: 'Saldo resmi server SETELAH tx ini diproses (isi dari response SYNCED). Device update amount_cent ke nilai ini — BUKAN hitung sendiri']
  reject_reason         text    [null,
                                  note: 'Alasan reject dari server: DOUBLE_SPEND | INSUFFICIENT_BALANCE | HOP_EXCEEDED | SIG_INVALID | EXPIRED | CASCADE_PARENT_REJECTED | CHAIN_FORK']
  note                  text    [null, note: 'Catatan bebas dari user']
  created_at            integer [not null]

  indexes {
    tx_id                       [unique, name: 'idx_tx_id']
    (mint_tx_id, hop_count)     [name: 'idx_chain_fork_check']
    sync_status                 [name: 'idx_sync_status']
    verify_status               [name: 'idx_verify_status']
    parent_tx_id                [name: 'idx_parent_tx']
    (user_id, transfer_medium)  [name: 'idx_user_medium']
    (user_id, tx_type)          [name: 'idx_user_txtype']
    (user_id, created_at)       [name: 'idx_user_created']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// rollback_queue — v4 BARU
//
// Antrian rollback yang BELUM dieksekusi ke wallet_balances.
// Dibuat oleh:
//   (a) device sendiri saat terima response REJECTED dari server
//   (b) device sendiri saat deteksi anomali lokal
//
// Kenapa tabel terpisah, bukan langsung update wallet_balances?
//   → Jika app crash saat rollback sedang berjalan, queue ini memastikan
//     rollback bisa dilanjutkan saat app restart (idempoten).
//   → Setiap item dieksekusi tepat satu kali (is_executed = true setelah done).
//
// APPEND-ONLY — tidak boleh dihapus, hanya is_executed di-update.
// ─────────────────────────────────────────────────────────────────────────────

Table rollback_queue {
  id              integer [pk, increment]
  user_id         integer [not null, ref: > users.id]
  tx_id           text    [not null, ref: > transactions.tx_id,
                            note: 'Transaksi yang harus di-rollback']
  rollback_type   text    [not null,
                            note: 'RELEASE_RESERVE | DEDUCT_RECEIVED | CASCADE_DEDUCT | SERVER_CORRECTION']
  amount_cent     integer [not null,
                            note: 'Nominal yang di-rollback. Untuk SERVER_CORRECTION: nilai target amount_cent dari server']
  reason          text    [not null,
                            note: 'Alasan rollback: sumber dari reject_reason server atau deteksi lokal']
  created_at      integer [not null, note: 'Saat rollback ini dijadwalkan']
  is_executed     boolean [not null, default: false,
                            note: 'false = belum dieksekusi. true = sudah. Cek ini sebelum eksekusi ulang (idempoten)']
  executed_at     integer [null, note: 'Saat rollback berhasil dieksekusi']

  indexes {
    (user_id, is_executed) [name: 'idx_rollback_pending']
    tx_id                  [name: 'idx_rollback_tx']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// anomaly_logs — v4
//
// Audit trail semua kejadian mencurigakan. APPEND-ONLY.
// Dikirim ke server saat sync sebagai bagian dari fraud detection pipeline.
// Server pakai ini untuk: flagging akun, analisis pola, blokir otomatis.
// ─────────────────────────────────────────────────────────────────────────────

Table anomaly_logs {
  id              integer [pk, increment]
  user_id         integer [not null, ref: > users.id]
  tx_id           text    [null,
                            note: 'tx_id terkait. NULL jika anomali terdeteksi sebelum tx dibuat (misal: hop exceeded saat mau SEND)']
  anomaly_type    text    [not null,
                            note: 'DOUBLE_SPEND_ATTEMPT | INSUFFICIENT_BALANCE | HOP_EXCEEDED | EXPIRED_TX | SIG_INVALID | REPLAY_ATTEMPT | TAMPERED_PAYLOAD | HOP_MISMATCH | CHAIN_FORK | RECEIVED_FRAUDULENT_TX | CASCADE_REJECTED']
  detected_at     integer [not null]
  detail          text    [null,
                            note: 'JSON konteks: { attempted_amount, spendable, claimed_hop, chain_hop, mint_tx_id, expires_at, now, ... }']
  raw_payload_b64 text    [null, note: 'Raw payload pemicu anomali (forensik server)']
  is_reported     boolean [not null, default: false]
  reported_at     integer [null]

  indexes {
    (user_id, anomaly_type) [name: 'idx_anomaly_type']
    is_reported             [name: 'idx_anomaly_queue']
    detected_at             [name: 'idx_anomaly_time']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// online_transactions — detail untuk transfer_medium = ONLINE
// ─────────────────────────────────────────────────────────────────────────────

Table online_transactions {
  id                  integer [pk, increment]
  tx_id               text    [not null, unique, ref: - transactions.tx_id]
  recipient_wallet_id text    [not null]
  recipient_name      text    [null]
  description         text    [null]
  request_sent_at     integer [not null]
  request_payload     text    [null, note: 'JSON snapshot untuk audit & idempotent retry']
  status              text    [not null, default: 'PENDING',
                                note: 'PENDING | SUCCESS | FAILED | CANCELLED']
  http_status         integer [null]
  server_tx_id        text    [null]
  server_response     text    [null]
  completed_at        integer [null]
  failure_reason      text    [null]
  retry_count         integer [not null, default: 0]
  last_retry_at       integer [null]

  indexes {
    tx_id  [unique, name: 'idx_online_tx_id']
    status [name: 'idx_online_status']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// sync_logs — log percobaan sync per-tx (offline only)
// ─────────────────────────────────────────────────────────────────────────────

Table sync_logs {
  id              integer [pk, increment]
  tx_id           text    [not null, ref: > transactions.tx_id]
  synced_at       integer [not null]
  http_status     integer [null]
  server_response text    [null]
  is_success      boolean [not null]
}

// ─────────────────────────────────────────────────────────────────────────────
// topup_requests
// ─────────────────────────────────────────────────────────────────────────────

Table topup_requests {
  id             integer [pk, increment]
  user_id        integer [not null, ref: > users.id]
  tx_id          text    [null, ref: > transactions.tx_id]
  amount_cent    integer [not null]
  currency       text    [not null, default: 'IDR']
  payment_method text    [not null, note: 'VIRTUAL_ACCOUNT | BANK_TRANSFER | QRIS']
  va_number      text    [null]
  bank_code      text    [null]
  status         text    [not null, default: 'PENDING',
                           note: 'PENDING | SUCCESS | EXPIRED | FAILED']
  server_ref     text    [null]
  expired_at     integer [null]
  confirmed_at   integer [null]
  created_at     integer [not null]

  indexes {
    (user_id, status) [name: 'idx_topup_user_status']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// claim_requests
// ─────────────────────────────────────────────────────────────────────────────

Table claim_requests {
  id              integer [pk, increment]
  user_id         integer [not null, ref: > users.id]
  tx_id           text    [not null, ref: > transactions.tx_id]
  reason          text    [not null]
  status          text    [not null, default: 'SUBMITTED',
                            note: 'SUBMITTED | UNDER_REVIEW | RESOLVED | REJECTED']
  server_claim_id text    [null]
  resolution      text    [null]
  submitted_at    integer [not null]
  resolved_at     integer [null]

  indexes {
    (user_id, status) [name: 'idx_claim_user_status']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// device_sessions
// ─────────────────────────────────────────────────────────────────────────────

Table device_sessions {
  id            integer [pk, increment]
  user_id       integer [not null, ref: > users.id]
  device_id     text    [null, note: 'Device fingerprint / FCM token']
  auth_token    text    [not null]
  refresh_token text    [null]
  expires_at    integer [not null]
  created_at    integer [not null]
}

// ─────────────────────────────────────────────────────────────────────────────
// contacts_cache
// ─────────────────────────────────────────────────────────────────────────────

Table contacts_cache {
  id            integer [pk, increment]
  owner_user_id integer [not null, ref: > users.id]
  wallet_id     text    [not null]
  display_name  text    [null]
  phone_number  text    [null]
  last_tx_at    integer [null]
  tx_count      integer [not null, default: 1]
  created_at    integer [not null]
  updated_at    integer [not null]

  indexes {
    (owner_user_id, wallet_id)  [unique, name: 'idx_contact_unique']
    (owner_user_id, last_tx_at) [name: 'idx_contact_recent']
  }
}
